{
  "name": "@mrkrstphr/beadee",
  "version": "0.11.0",
  "description": "Web GUI for the beads issue tracker",
  "type": "module",
  "bin": {
    "beadee": "./bin/beadee.js"
  },
  "files": [
    "bin/",
    "build/",
    "server/"
  ],
  "scripts": {
    "test": "vitest",
    "dev": "react-router dev",
    "build": "react-router build && tsc -p tsconfig.server.json",
    "start": "node bin/beadee.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-router/node": "7.14.2",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query": "5.100.5",
    "dompurify": "3.4.1",
    "isbot": "5.1.39",
    "lucide-react": "1.11.0",
    "marked": "18.0.2",
    "open": "11.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.14.2",
    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint-react/eslint-plugin": "4.2.3",
    "@eslint/css": "1.1.0",
    "@eslint/js": "10.0.1",
    "@react-router/dev": "7.14.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/ui": "4.1.5",
    "eslint": "10.2.1",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "tailwind-csstree": "0.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "5.4.21",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "beads",
    "issue-tracker",
    "cli",
    "gui"
  ],
  "license": "MIT"
}
